{
  "name": "aws-console-masking",
  "displayName": "AWS Console Masking",
  "version": "0.0.2",
  "description": "AWSコンソール画面の機密情報を黒塗りする拡張機能",
  "author": "asano.haruki",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.15.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.6.2",
    "@types/chrome": "0.1.4",
    "@types/node": "24.3.0",
    "@types/react": "19.1.11",
    "@types/react-dom": "19.1.8",
    "prettier": "3.6.2",
    "svgo": "^4.0.0",
    "typescript": "5.9.2"
  },
  "pnpm": {
    "overrides": {
      "svgo": "^4.0.0",
      "glob": ">=10.5.0",
      "msgpackr@<1.10.1": ">=1.10.1",
      "svelte@<4.2.19": ">=4.2.19",
      "esbuild@<=0.24.2": ">=0.25.0",
      "content-security-policy-parser@<0.6.0": ">=0.6.0",
      "svelte@<=5.51.4": ">=5.51.5",
      "rollup@>=3.0.0 <3.30.0": ">=3.30.0",
      "svelte@<=5.53.4": ">=5.53.5"
    }
  },
  "plasmo": {
    "popup": {
      "entry": "src/popup/index.tsx"
    }
  },
  "manifest": {
    "host_permissions": [
      "https://*.console.aws.amazon.com/*",
      "https://console.aws.amazon.com/*"
    ],
    "permissions": [
      "storage",
      "tabs"
    ]
  },
  "packageManager": "pnpm@10.23.0+sha512.21c4e5698002ade97e4efe8b8b4a89a8de3c85a37919f957e7a0f30f38fbc5bbdd05980ffe29179b2fb6e6e691242e098d945d1601772cad0fef5fb6411e2a4b"
}
